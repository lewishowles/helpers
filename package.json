{
	"name": "@lewishowles/helpers",
	"version": "0.20.0",
	"description": "A library of gorgeous Javascript methods to make working with—and validating—data quicker and less error-prone, letting the developer concentrate on the fun stuff.",
	"keywords": [
		"array",
		"form",
		"helpers",
		"javascript",
		"object",
		"string",
		"utilities",
		"validation",
		"vue"
	],
	"homepage": "https://github.com/lewishowles/helpers#readme",
	"bugs": "https://github.com/lewishowles/helpers/issues",
	"license": "MIT",
	"author": "Lewis Howles",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lewishowles/helpers.git"
	},
	"files": [
		"dist",
		"types"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./array": {
			"import": {
				"types": "./types/array.d.ts",
				"default": "./dist/array.js"
			},
			"require": {
				"types": "./types/array.d.cts",
				"default": "./dist/array.cjs"
			}
		},
		"./form": {
			"import": {
				"types": "./types/form.d.ts",
				"default": "./dist/form.js"
			},
			"require": {
				"types": "./types/form.d.cts",
				"default": "./dist/form.cjs"
			}
		},
		"./general": {
			"import": {
				"types": "./types/general.d.ts",
				"default": "./dist/general.js"
			},
			"require": {
				"types": "./types/general.d.cts",
				"default": "./dist/general.cjs"
			}
		},
		"./number": {
			"import": {
				"types": "./types/number.d.ts",
				"default": "./dist/number.js"
			},
			"require": {
				"types": "./types/number.d.cts",
				"default": "./dist/number.cjs"
			}
		},
		"./object": {
			"import": {
				"types": "./types/object.d.ts",
				"default": "./dist/object.js"
			},
			"require": {
				"types": "./types/object.d.cts",
				"default": "./dist/object.cjs"
			}
		},
		"./string": {
			"import": {
				"types": "./types/string.d.ts",
				"default": "./dist/string.js"
			},
			"require": {
				"types": "./types/string.d.cts",
				"default": "./dist/string.cjs"
			}
		},
		"./vue": {
			"import": {
				"types": "./types/vue.d.ts",
				"default": "./dist/vue.js"
			},
			"require": {
				"types": "./types/vue.d.cts",
				"default": "./dist/vue.cjs"
			}
		},
		"./url": {
			"import": {
				"types": "./types/url.d.ts",
				"default": "./dist/url.js"
			},
			"require": {
				"types": "./types/url.d.cts",
				"default": "./dist/url.cjs"
			}
		}
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"scripts": {
		"dev": "vp dev",
		"test:unit": "vp test",
		"test:unit:run": "vp test run",
		"build": "vp build",
		"preview": "vp preview",
		"check": "vp check --fix",
		"docs:readme": "node support/generate-readme.js",
		"check:exports": "support/check-exports.sh",
		"check:package-size": "support/check-package-size.sh",
		"check:readme": "support/check-readme.sh",
		"check:runtime-deps": "support/check-runtime-deps.sh",
		"check:test-coverage": "support/check-test-coverage.sh",
		"check:type-declarations": "support/check-type-declarations.sh",
		"publint": "publint",
		"attw": "support/check-attw.sh",
		"prepare": "vp config"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.3",
		"@stylistic/eslint-plugin": "^5.10.0",
		"globals": "^17.6.0",
		"happy-dom": "^20.10.2",
		"publint": "^0.3.21",
		"vite": "8.0.16",
		"vite-plus": "^0.1.24",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest",
		"vue": "^3.5.38"
	},
	"engines": {
		"node": ">=20"
	}
}

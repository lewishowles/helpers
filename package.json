{
	"name": "@lewishowles/helpers",
	"version": "0.20.0",
	"description": "A library of gorgeous Javascript methods to make working with—and validating—data quicker and less error-prone, letting the developer concentrate on the fun stuff.",
	"keywords": [
		"array",
		"form",
		"helpers",
		"javascript",
		"object",
		"string",
		"utilities",
		"validation",
		"vue"
	],
	"homepage": "https://github.com/lewishowles/helpers#readme",
	"bugs": "https://github.com/lewishowles/helpers/issues",
	"license": "MIT",
	"author": "Lewis Howles",
	"repository": {
		"type": "git",
		"url": "https://github.com/lewishowles/helpers.git"
	},
	"files": [
		"dist",
		"types"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./array": {
			"types": "./types/array.d.ts",
			"import": "./dist/array.js",
			"require": "./dist/array.cjs"
		},
		"./form": {
			"types": "./types/form.d.ts",
			"import": "./dist/form.js",
			"require": "./dist/form.cjs"
		},
		"./general": {
			"types": "./types/general.d.ts",
			"import": "./dist/general.js",
			"require": "./dist/general.cjs"
		},
		"./number": {
			"types": "./types/number.d.ts",
			"import": "./dist/number.js",
			"require": "./dist/number.cjs"
		},
		"./object": {
			"types": "./types/object.d.ts",
			"import": "./dist/object.js",
			"require": "./dist/object.cjs"
		},
		"./string": {
			"types": "./types/string.d.ts",
			"import": "./dist/string.js",
			"require": "./dist/string.cjs"
		},
		"./vue": {
			"types": "./types/vue.d.ts",
			"import": "./dist/vue.js",
			"require": "./dist/vue.cjs"
		},
		"./url": {
			"types": "./types/url.d.ts",
			"import": "./dist/url.js",
			"require": "./dist/url.cjs"
		}
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"scripts": {
		"dev": "vp dev",
		"test:unit": "vp test",
		"test:unit:run": "vp test run",
		"lint": "vp check . --fix",
		"build": "vp build",
		"preview": "vp preview",
		"docs:readme": "node support/generate-readme.js",
		"check:readme": "support/check-readme.sh",
		"publint": "publint",
		"attw": "attw --pack",
		"prepare": "vp config"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.3",
		"@stylistic/eslint-plugin": "^5.10.0",
		"globals": "^17.6.0",
		"happy-dom": "^20.10.2",
		"publint": "^0.3.21",
		"vite": "8.0.16",
		"vite-plus": "^0.1.24",
		"vitest": "npm:@voidzero-dev/vite-plus-test@latest",
		"vue": "^3.5.38"
	},
	"engines": {
		"node": ">=20"
	}
}
